# Server
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# IMAP
IMAP_HOST=mail.example.com
IMAP_PORT=993
IMAP_USERNAME=lawyer@example.com
IMAP_PASSWORD=change-me
IMAP_USE_SSL=true
IMAP_TIMEOUT_SECONDS=30
IMAP_RETRY_COUNT=1

# Folder security
CASE_FOLDER_ALLOWLIST_REGEX=^Client/.+
SENT_FOLDER_ALLOWLIST_REGEX=^(Sent|Sent Items|INBOX\\.Sent)$
DEFAULT_SENT_FOLDERS=Sent,Sent Items
ALLOW_GLOBAL_SEARCH=false

# Limits
MAX_RESULTS=50
MAX_RETURN_BYTES=262144
MAX_SEARCH_SCAN=500
MAX_THREAD_SCAN=400
MAX_ATTACHMENT_BYTES=10485760
MAX_ATTACHMENT_EXTRACT_CHARS=20000
MAX_BODY_CHARS=50000
MAX_SNIPPET_CHARS=400

# Message references and cache
MESSAGE_REF_SECRET=replace-with-a-long-random-secret
CACHE_ENABLED=true
CACHE_DB_PATH=.cache/casemail_cache.sqlite3
CACHE_KEY_PATH=.cache/casemail_cache.key
CACHE_TTL_HOURS=168

